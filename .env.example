# =======================================================================
# Public BYO-credentials mode (default - required for demo.truv.com)
# =======================================================================
#
# In BYO mode, visitors plug in their own Truv API credentials at runtime.
# The server holds them in memory per-session; nothing hits disk.

# Public origin the customer's Truv account will reach us at.
# Used to build per-session webhook URLs: <PUBLIC_BASE_URL>/api/webhooks/truv/<sid>
PUBLIC_BASE_URL=

# Random secret used to sign the session cookie. Must be at least 32 chars.
# If unset, a per-process random value is generated and sessions reset on each restart.
SESSION_COOKIE_SECRET=

# Optional. Sessions are evicted after this many ms of inactivity (default 1h).
# SESSION_IDLE_TTL_MS=3600000

# =======================================================================
# Local dev fallback (off by default)
# =======================================================================
#
# Set ALLOW_ENV_FALLBACK_CREDS=true to keep the pre-BYO behavior: one shared
# TruvClient built from .env, one shared webhook URL via NGROK_URL, no
# Configure screen required on first visit.

# ALLOW_ENV_FALLBACK_CREDS=true

# Truv API credentials (required only when ALLOW_ENV_FALLBACK_CREDS=true).
# Get these from https://dashboard.truv.com/app/development/keys
API_CLIENT_ID=
API_SECRET=

# Ngrok tunnel URL (required only when ALLOW_ENV_FALLBACK_CREDS=true).
# Run: ngrok http 3000, then paste the forwarding URL here.
NGROK_URL=
