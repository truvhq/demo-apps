# =======================================================================
# Local development  (this is all you need to run the demos)
# =======================================================================
#
# Add your Truv sandbox keys below, then:  npm start  +  npm run dev
#
# With no PUBLIC_BASE_URL set (see Deployment, far below), the server runs in
# local mode: it uses these keys for every request and skips the Configure
# screen. Get keys at https://dashboard.truv.com/app/development/keys

API_CLIENT_ID=
API_SECRET=

# Optional - receive webhooks on localhost. Run `ngrok http 3000` and paste the
# forwarding URL here. Without it the demos still run end-to-end; only inbound
# webhook delivery is unavailable.
NGROK_URL=


# =======================================================================
# Deployment  (hosted / multi-tenant - NOT needed for local dev)
# =======================================================================
#
# Setting PUBLIC_BASE_URL switches the server to hosted mode: each visitor
# brings their own Truv keys via the Configure screen and the keys above are
# ignored. Full guide: docs/DEPLOYMENT.md

# Public origin the visitor's Truv account reaches you at. Builds per-session
# webhook URLs: <PUBLIC_BASE_URL>/api/webhooks/truv/<sid>
PUBLIC_BASE_URL=

# Random secret used to sign session cookies (32+ chars). If unset, a
# per-process random value is generated and sessions reset on each restart.
SESSION_COOKIE_SECRET=

# Force the run mode explicitly, overriding the PUBLIC_BASE_URL inference:
#   true  -> local mode (use API_CLIENT_ID / API_SECRET above)
#   false -> hosted mode
# ALLOW_ENV_FALLBACK_CREDS=

# Sessions are evicted after this many ms of inactivity (default 1h).
# SESSION_IDLE_TTL_MS=3600000

# Origin for the "Get API keys" / "webhook config" links in the UI. Read at
# runtime and injected into the served HTML, so one build can target any
# environment. Defaults to prod when unset.
# DASHBOARD_URL=https://dashboard.truv.com

# --- Sign in with Truv (SSO) - optional -------------------------------
#
# When all three VITE_AUTH0_* vars are set, the Configure screen leads with
# "Sign in with Truv" instead of the paste form: Auth0 PKCE on the frontend,
# and the backend trades the access token for the user's sandbox keys via
# dashboard-backend-prod.truv.com. If any is missing, the SSO route returns
# 503 sso_disabled and Configure falls back to paste-only mode.

VITE_AUTH0_DOMAIN=auth.truv.com
VITE_AUTH0_CLIENT_ID=
VITE_AUTH0_AUDIENCE=https://dashboard-backend-prod.truv.com/

# Override the dashboard backend URL used for the SSO key fetch (defaults to prod).
# DASHBOARD_BACKEND_URL=https://dashboard-backend-prod.truv.com
