{
  "info": {
    "name": "Truv Public Sector Demo",
    "_postman_id": "truv-public-sector-demo",
    "description": "API collection for Truv public sector integration demos. Uses sandbox credentials.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "https://prod.truv.com/v1"
    },
    {
      "key": "client_id",
      "value": "your_sandbox_client_id"
    },
    {
      "key": "client_secret",
      "value": "your_sandbox_secret"
    },
    {
      "key": "order_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Create Order",
      "request": {
        "method": "POST",
        "header": [
          { "key": "Content-Type", "value": "application/json" },
          { "key": "X-Access-Client-Id", "value": "{{client_id}}" },
          { "key": "X-Access-Secret", "value": "{{client_secret}}" }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n  \"product_type\": \"income\",\n  \"consumer\": {\n    \"first_name\": \"John\",\n    \"last_name\": \"Doe\",\n    \"ssn\": \"991-91-9991\"\n  }\n}"
        },
        "url": {
          "raw": "{{base_url}}/orders/",
          "host": ["{{base_url}}"],
          "path": ["orders", ""]
        }
      }
    },
    {
      "name": "Get Order",
      "request": {
        "method": "GET",
        "header": [
          { "key": "X-Access-Client-Id", "value": "{{client_id}}" },
          { "key": "X-Access-Secret", "value": "{{client_secret}}" }
        ],
        "url": {
          "raw": "{{base_url}}/orders/{{order_id}}/",
          "host": ["{{base_url}}"],
          "path": ["orders", "{{order_id}}", ""]
        }
      }
    },
    {
      "name": "Refresh Order",
      "request": {
        "method": "POST",
        "header": [
          { "key": "X-Access-Client-Id", "value": "{{client_id}}" },
          { "key": "X-Access-Secret", "value": "{{client_secret}}" }
        ],
        "url": {
          "raw": "{{base_url}}/orders/{{order_id}}/refresh/",
          "host": ["{{base_url}}"],
          "path": ["orders", "{{order_id}}", "refresh", ""]
        }
      }
    }
  ]
}
